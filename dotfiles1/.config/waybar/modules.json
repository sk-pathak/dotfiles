{
    // Workspaces
    "hyprland/workspaces" : {
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
			"urgent": "",
			"active": "",
			"default": ""
        },
        "persistent_workspaces": {
             "*": 4
        }       
    },

    // Taskbar
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": [
           "kitty"
        ],
        "app_ids-mapping": {
            "firefoxdeveloperedition": "firefox-developer-edition"
        },
        "rewrite": {
            "Firefox Web Browser": "Firefox",
            "Kitty Server": "Terminal"
        }
    },

    // Hyprland Window
    "hyprland/window": {
        "rewrite": {
          "nvim (.*)": "яДб  $1",
          "vim (.*)": "яДб  $1",
          "thunar(.*)": "юлм $1",
          "kitty (.*)": "яТЙ  $1",
          "Search(.*)": "юЩД Search$1"
        },
        "separate-outputs": true
    },

    // Updates Count
    "custom/updates": {
        "format": "яВл  {}",
        "tooltip-format": "{}",
        "escape": true,
        "return-type": "json",       
        "exec": "~/.config/hypr/scripts/updates.sh",
        "restart-interval": 60,
        "on-click": "kitty -e ~/dotfiles/scripts/installupdates.sh",
        "tooltip": false
    },
    
    // Wallpaper
    "custom/wallpaper": {
        "format": "яА╛",
        "on-click": "~/.config/hypr/scripts/wallpaper.sh select",
        "on-click-right": "~/.config/hypr/scripts/wallpaper.sh",
        "tooltip": false
    },

    // Waybar Themes
    "custom/waybarthemes": {
        "format": "яЕБ",
        "on-click": "~/.config/waybar/themeswitcher.sh",
        "tooltip": false
    },

    // Filemanager Launcher
    "custom/filemanager": {
        "format": "яБ╗",
        "on-click": "thunar",
        "tooltip": false
    },

    // Firefox Launcher
    "custom/firefox": {
        "format": "яЙй  ",
        "on-click": "firefox --private-window",
        "tooltip": false
    },

    // Rofi Application Launcher
    "custom/appmenu": {
        "format": " яМГ ",
        "on-click": "rofi -show drun",
        "tooltip": false
    },
    
    // Power Menu
    "custom/exit": {
        "format": "яАС",
        "on-click": "wlogout",
        "tooltip": false
    },

    // System tray
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    // Clock
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    // CPU
    "cpu": {
        "format": "яТ╝   {usage}%  ",
        "on-click": "kitty -e gotop"
    },

    // Memory
    "memory": {
        "format": "ґ░Сн  {}% ",
        "on-click": "kitty -e gotop"
    },

    // Harddisc space used
    "disk": {
        "interval": 30,
        "format": "яВа  {percentage_used}%  ",
        "path": "/",
        "on-click": "kitty -e gotop"
    }, 
    
    // Network
    "network": {
        "format": "{ifname}",
        "format-wifi": "яЗл   {signalStrength}%",
        "format-ethernet": "яЮЦ  {ipaddr}",
        "format-disconnected": "Not connected", //An empty format will hide the module.
        "tooltip-format": "яЮЦ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "яЗл   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "яГБ  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "iwgtk"
    },

    // Battery
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "яЗж   {capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        "format-alt": "{icon}  {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "]
    },

    // Pulseaudio
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яАж {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яАе ",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАи ", "яАи "]
        },
        "on-click": "pavucontrol"
    },

    // Bluetooth
    "bluetooth": {
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueberry"
    },

    // Other
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false,
    }
}
