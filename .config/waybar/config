{
    "layer": "top",
    "position": "top",
    "margin-bottom": 0,
    "modules-left": [
      "clock",
      "hyprland/workspaces",
      "custom/updates",
      "tray",
      ],
    "modules-center": [
      "hyprland/window",
      ],
    "modules-right": [
      "network",
      "temperature",
      "memory",
      "cpu",
      "pulseaudio",
      "custom/powermenu",
    ],
    "tray": {
      "icon-size": 24,
      "spacing": 10
    },
    "hyprland/window": {
      "format": " {}",
      "rewrite": {
          "(\\d\\. )?(.*) - Chromium": "<span color=\"#4285F4\">ΎΚρ</span>  $2 ",
          "nvim (.*)": "<span color=\"#57A143\">ΎΕκ </span>  $1",
          "nvim": "<span color=\"#57A143\">ΎΕκ  Neovim</span> ",
          "vim (.*)": "<span color=\"#57A143\">ΎΕκ </span>  $1",
          "vim": "<span color=\"#57A143\">ΎΕκ  Neovim</span> ",
          "ranger(.*)": "<span color=\"#ffffff\">Ότυ </span>  $1",
          "kitty (.*)": "<span color=\"#ffffff\">ΎΤΚ </span>  $1",
          "Search(.*)": "<span color=\"#a855f7\">ΌβΕ </span>  Search$1",
      },
      "separate-outputs": true
    },
    "hyprland/submap": {
      "format": "έεΝΎ╕Π {}",
      "max-length": 8,
      "tooltip": true
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "≤░▓ι",
        "2": "≤░▓λ",
        "3": "≤░▓ν",
        "4": "≤░▓ο",
        "5": "≤░▓ρ",
        "6": "≤░▓ς",
        "7": "≤░▓υ",
        "8": "≤░▓χ",
        "9": "≤░▓░",
        "10": "≤░┐υ",
        "-99": "Όυμ",
        "active": "ΎΕΣ",
        "default": "ΎΕΝ"
      }
    },
    "network": {
      "interface": "wlan0",
      "tooltip-format-ethernet": "{ifname} ΎΔΒ",
      "interval": 2,
      "format": " ΎΑβ  {bandwidthDownBits}   ΎΓΥ  {bandwidthUpBits}",
      "on-click": "kitty -e nmtui"
    },
    "temperature": {
      "format": "{icon} {temperatureC}┬░C",
      "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
      "critical-threshold": 80,
      "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"]
    },
    "memory": {
      "format": "ΌΝλ  {}%",
      "tooltip": "false"
    },
    "cpu": {
      "format": "ΌΚο  {usage}%",
      "tooltip": "false"
    },
    "custom/powermenu": {
      "format": "ΎΑΣ",
      "tooltip": false,
      "on-click": "exec wlogout -p layer-shell",
    },
    "custom/updates": {
      "format": "<span color=\"#61afef\">ΎΓς </span> {}",
      "tooltip": false,
      "interval": 3600,
      "exec": "exec $HOME/.config/waybar/checkupdate.sh"
    },
    "pulseaudio": {
      "format": "{volume}% {icon}",
      "format-bluetooth": "{volume}% {icon}ΎΛΦ",
      "format-muted": "ΎΑο ",
      "format-icons": {
          "headphone": "ΎΑξ ",
          "hands-free": "ΎΨΡ",
          "headset": "ΎΑξ ",
          "phone": "ΎΓΧ ",
          "portable": "ΎΓΧ ",
          "car": "ΎΗ╣ ",
          "default": ["ΎΑπ ", "ΎΑρ "]
      },
      "scroll-step": 5,
      "on-click": "pavucontrol"
    },
    "clock": {
      "format": "<span color=\"#56b6c2\">ΎΑΩ </span> {:%H:%M}",
      "interval": 60,
      "tooltip": true,
      "tooltip-format": "{:%d %B %H:%M}"
    },
}
